# PostgreSQL (docker-compose.yml の db サービスに接続)
DATABASE_URL="postgresql://mahjong:mahjong@localhost:5432/mahjong"

# サーバー
PORT=3001
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Firebase (Firebase Console から取得)
FIREBASE_PROJECT_ID=

# Firebase Admin SDK 認証情報(JSON)のパス
# 例: C:\\secrets\\firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=
